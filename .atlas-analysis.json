{
  "projectType": "api-service",
  "projectName": "Pelupatas Backend API",
  "projectDescription": "A PHP REST API backend for a pet grooming (peluquería canina) management system, handling users, pets, and appointments with JWT authentication.",
  "theme": "luma",
  "primaryColor": "#7C3AED",
  "lightColor": "#EDE9FE",
